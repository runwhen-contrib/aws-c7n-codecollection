{
  "policy": {
    "name": "high-risk-security-groups",
    "resource": "security-group",
    "description": "Detect any rule from a security group that allows 0.0.0.0/0 or ::/0 (IPv6) ingress\n",
    "filters": [
      {
        "or": [
          {
            "type": "ingress",
            "Cidr": {
              "value": "0.0.0.0/0",
              "key": "CidrIp"
            }
          },
          {
            "type": "ingress",
            "CidrV6": {
              "value": "::/0"
            }
          }
        ]
      }
    ]
  },
